{
  "expo": {
    "name": "Suds",
    "autolinking": {
      "searchPaths": ["./modules"]
    },
    "slug": "suds",
    "version": "1.1.1",
    "orientation": "portrait",
    "icon": "./assets/Suds.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/Suds.png",
      "resizeMode": "contain",
      "backgroundColor": "#F59E0B"
    },
    "scheme": "suds",
    "ios": {
      "appleTeamId": "935735W5AA",
      "supportsTablet": false,
      "bundleIdentifier": "com.sudssocial.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Suds uses your location to tag where you had drinks.",
        "NSCameraUsageDescription": "Suds uses your camera to add photos to drink logs.",
        "NSPhotoLibraryUsageDescription": "Suds uses your photo library to add photos to drink logs.",
        "NSContactsUsageDescription": "Suds uses your contacts to help you find friends.",
        "NSSupportsLiveActivities": true,
        "ITSAppUsesNonExemptEncryption": false
      },
      "entitlements": {
        "com.apple.security.application-groups": ["group.com.sudssocial.app"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/Suds.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/Suds.png"
      },
      "package": "com.sudssocial.app",
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_CONTACTS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/Suds.png"
    },
    "plugins": [
      "./plugins/withModularHeaders",
      ["expo-router", { "origin": "https://drink-with-suds.com" }],

      "expo-location",
      [
        "expo-notifications",
        {
          "icon": "./assets/Suds.png",
          "color": "#F59E0B",
          "sounds": [],
          "iosDisplayInForeground": true,
          "mode": "production"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Suds to access your photos."
        }
      ],
      "expo-font",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.213568095545-pmv2qmc5j2po98r8u4j1k936k50mif93"
        }
      ],
      "@bacons/apple-targets",
      [
        "expo-contacts",
        {
          "contactsPermission": "Allow Suds to access your contacts to find friends."
        }
      ],
      "./plugins/withLiveActivityBridge"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "12c7fee8-d880-4426-8732-0c6af1c9845a"
      }
    }
  }
}
